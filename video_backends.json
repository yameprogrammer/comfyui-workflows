{
  "version": 3,
  "description": "I2V backend + format SSOT. Deliver pixel tiers (deliver_1080/2160…) live in upscale_backends.json; format only picks aspect. See docs/video_delivery_and_backends.md",
  "default_backend": "wan22",
  "default_backend_s2v": "ltx23_ia2v",
  "default_format": "cinematic_16x9",
  "default_work_preset": "work_16x9_540",
  "default_deliver_tier": "deliver_1080",
  "formats": {
    "cinematic_16x9": {
      "aspect": "16:9",
      "orientation": "landscape",
      "use_cases": ["youtube", "cinema", "web_horizontal"],
      "default_work_preset": "work_16x9_540",
      "default_deliver_tier": "deliver_1080",
      "notes": "Wide landscape; common default when no format specified"
    },
    "shorts_9x16": {
      "aspect": "9:16",
      "orientation": "portrait",
      "use_cases": ["shorts", "reels", "tiktok", "stories"],
      "default_work_preset": "work_9x16_540",
      "default_deliver_tier": "deliver_1080",
      "notes": "Vertical short-form"
    },
    "classic_4x3": {
      "aspect": "4:3",
      "orientation": "landscape",
      "use_cases": ["classic_tv", "presentation", "retro"],
      "default_work_preset": "work_4x3_540",
      "default_deliver_tier": "deliver_1080",
      "notes": "Traditional 4:3 landscape"
    },
    "portrait_3x4": {
      "aspect": "3:4",
      "orientation": "portrait",
      "use_cases": ["portrait_photo_style", "print_like", "app_vertical"],
      "default_work_preset": "work_3x4_540",
      "default_deliver_tier": "deliver_1080",
      "notes": "Soft vertical (less tall than 9:16)"
    },
    "square_1x1": {
      "aspect": "1:1",
      "orientation": "square",
      "use_cases": ["feed_square", "smoke_test"],
      "default_work_preset": "work_1x1_smoke",
      "default_deliver_tier": "deliver_1080",
      "notes": "Square; also used for legacy smoke tests"
    }
  },
  "deliver_aliases": {
    "deliver_16x9_1080": "deliver_1080",
    "deliver_9x16_1080": "deliver_1080",
    "deliver_4x3_1080": "deliver_1080",
    "deliver_3x4_1080": "deliver_1080",
    "deliver_1x1_1080": "deliver_1080",
    "deliver_16x9_2160": "deliver_2160",
    "deliver_9x16_2160": "deliver_2160"
  },
  "presets": {
    "work_16x9_360": {
      "width": 640,
      "height": 368,
      "aspect": "16:9",
      "stage": "work",
      "notes": "smoke / fastest landscape; H/W multiple of 16 for Wan"
    },
    "work_16x9_540": {
      "width": 960,
      "height": 544,
      "aspect": "16:9",
      "stage": "work",
      "notes": "default work for cinematic_16x9; 960x544 (not 540) so H%16==0 for Wan I2V"
    },
    "work_16x9_720": {
      "width": 1280,
      "height": 720,
      "aspect": "16:9",
      "stage": "work",
      "notes": "higher quality when VRAM allows"
    },
    "work_9x16_540": {
      "width": 544,
      "height": 960,
      "aspect": "9:16",
      "stage": "work",
      "notes": "vertical shorts work; W multiple of 16 for Wan"
    },
    "work_4x3_540": {
      "width": 720,
      "height": 544,
      "aspect": "4:3",
      "stage": "work",
      "notes": "classic 4:3 work (~short edge 544, multiple of 16)"
    },
    "work_3x4_540": {
      "width": 544,
      "height": 720,
      "aspect": "3:4",
      "stage": "work",
      "notes": "portrait 3:4 work; W multiple of 16 for Wan"
    },
    "work_1x1_smoke": {
      "width": 640,
      "height": 640,
      "aspect": "1:1",
      "stage": "work",
      "notes": "square smoke / feed"
    },
    "deliver_16x9_1080": {
      "width": 1920,
      "height": 1080,
      "aspect": "16:9",
      "stage": "deliver",
      "deprecated": true,
      "alias_tier": "deliver_1080",
      "notes": "DEPRECATED: use format + upscale --preset deliver_1080"
    },
    "deliver_9x16_1080": {
      "width": 1080,
      "height": 1920,
      "aspect": "9:16",
      "stage": "deliver",
      "deprecated": true,
      "alias_tier": "deliver_1080",
      "notes": "DEPRECATED: use format shorts_9x16 + deliver_1080"
    },
    "deliver_4x3_1080": {
      "width": 1440,
      "height": 1080,
      "aspect": "4:3",
      "stage": "deliver",
      "deprecated": true,
      "alias_tier": "deliver_1080",
      "notes": "DEPRECATED"
    },
    "deliver_3x4_1080": {
      "width": 1080,
      "height": 1440,
      "aspect": "3:4",
      "stage": "deliver",
      "deprecated": true,
      "alias_tier": "deliver_1080",
      "notes": "DEPRECATED"
    },
    "deliver_1x1_1080": {
      "width": 1080,
      "height": 1080,
      "aspect": "1:1",
      "stage": "deliver",
      "deprecated": true,
      "alias_tier": "deliver_1080",
      "notes": "DEPRECATED"
    }
  },
  "backends": {
    "wan22": {
      "status": "ready",
      "engine": "Wan2.2 I2V A14B GGUF",
      "workflow": "i2v_wan22_a14b",
      "strengths": ["character_i2v", "general_cinematic"],
      "notes": "GGUF dual high/low + lightx2v 4step; default backend"
    },
    "ltx23": {
      "status": "planned",
      "engine": "LTX 2.3",
      "workflow": "i2v_ltx23",
      "strengths": ["fast_iteration", "alt_motion"],
      "notes": "General I2V (non-SI2V). Local GGUF ready; agent I2V runner not wired yet."
    },
    "infinitetalk": {
      "status": "ready",
      "kind": "s2v",
      "engine": "Wan 2.1 I2V + InfiniteTalk (WanVideoWrapper)",
      "workflow": "scripts/generate_s2v.py --backend infinitetalk",
      "strengths": ["lip_sync", "talking_head", "music_video_vocal_cut", "face_stability", "hero_cut"],
      "notes": "HERO lips only (not agent default). Best lip lock; full 960@20step ~10–12min/5s on 4090. Use --profile hero (832/16fps/12step, still no lightx2v graph). lightx2v LoRA exists locally but graph wire deferred."
    },
    "ltx23_ia2v": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX 2.3 AIO real workflow (alias → i2v_audio mode switches)",
      "workflow": "scripts/generate_s2v.py --backend ltx23_ia2v",
      "strengths": ["fast_iteration", "custom_audio_i2v", "agent_default", "preview", "deliver"],
      "notes": "Alias of AIO i2v_audio. Uses [[P:]] switch on human AIO UI WF via ltx_aio_workflow_runner (not mini-graph)."
    },
    "ltx23_aio": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX 2.3 AIO modes via Orchestrator [[P:]] mute + UI expand",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio*",
      "manifest": "workflows/agent/ltx23_aio.manifest.json",
      "source_ui": "workflows/human/ltx23AllInOneWorkflowForRTX_v44.json",
      "source_ui_ia2v": "workflows/human/ltx23AllInOneWorkflowForRTX_v44_IA2V.json",
      "runner": "lib/ltx_aio_workflow_runner.py",
      "strengths": ["fast_iteration", "lip_sync", "custom_audio_i2v", "flf", "user_validated_aio"],
      "notes": "Modes: i2v, i2v_audio, flf, flf_audio, fml, fml_audio, v2v, v2v_audio, t2v, t2v_audio. Real WF switch/select — not mini graphs."
    },
    "ltx23_aio_i2v": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX AIO Image to Video (no audio) — switch select",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio_i2v",
      "strengths": ["establishing", "motion_only"]
    },
    "ltx23_aio_flf": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX AIO First/Last Frame — switch select",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio_flf --last last.png",
      "strengths": ["one_take_bridge", "flf2v"]
    },
    "ltx23_aio_flf_audio": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX AIO First/Last + Audio — switch select",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio_flf_audio --last last.png -a drive.wav",
      "strengths": ["one_take_bridge", "lip_sync", "flf2v"]
    },
    "ltx23_aio_fml": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX AIO First/Mid/Last — switch select",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio_fml --mid mid.png --last last.png"
    },
    "ltx23_aio_fml_audio": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX AIO First/Mid/Last + Audio — switch select",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio_fml_audio --mid mid.png --last last.png -a drive.wav"
    },
    "ltx23_aio_v2v": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX AIO Video to Video — switch select (legacy alias)",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio_v2v -i still.png [-v drive.mp4]",
      "notes": "Legacy name. Prefer ltx23_aio_v2v_true + generate_v2v for reference-video intents. Without -v behaves like still-conditioned path."
    },
    "ltx23_aio_v2v_audio": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX AIO V2V + Audio — switch select (legacy alias)",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio_v2v_audio -i ref.png -a drive.wav [-v video.mp4]"
    },
    "ltx23_aio_v2v_true": {
      "status": "experimental",
      "kind": "v2v",
      "engine": "LTX AIO [[P:03 Video to Video]] + VHS_LoadVideo (true -v)",
      "workflow": "scripts/generate_v2v.py --intent camera|motion|style -v ref.mp4 -i key.png",
      "intents": ["camera", "motion", "style"],
      "strengths": ["camera_plate", "motion_retarget", "style_transfer"],
      "notes": "SSOT: docs/v2v_intent_pipeline_design.md. Requires driving video copy into Comfy input."
    },
    "ltx23_aio_v2v_true_audio": {
      "status": "experimental",
      "kind": "v2v",
      "engine": "LTX AIO V2V + Audio ports",
      "workflow": "scripts/generate_v2v.py --intent motion -v ref.mp4 -i key.png -a drive.wav",
      "intents": ["camera", "motion", "style"],
      "notes": "Optional audio track; not a substitute for SI2V lips."
    },
    "ltx23_aio_t2v": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX AIO Text to Video — switch select",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio_t2v -i dummy.png --prompt '...'"
    },
    "ltx23_aio_t2v_audio": {
      "status": "ready",
      "kind": "s2v",
      "engine": "LTX AIO Text + Audio — switch select",
      "workflow": "scripts/generate_s2v.py --backend ltx23_aio_t2v_audio -i dummy.png -a drive.wav"
    },
    "wan_s2v": {
      "status": "planned",
      "kind": "s2v",
      "engine": "WanVideo Add S2V Embeds",
      "workflow": null,
      "strengths": ["audio_driven_motion"],
      "notes": "WanVideoAddS2VEmbeds + s2v example jsons in custom_nodes/.../s2v/"
    }
  }
}
