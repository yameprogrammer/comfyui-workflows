{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EpisodeCommissionBrief",
  "type": "object",
  "required": ["episode_id", "format", "shots"],
  "properties": {
    "episode_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "title": { "type": "string" },
    "logline": { "type": "string" },
    "format": { "type": "string" },
    "look_id": { "type": "string" },
    "production_mode": {
      "type": "string",
      "enum": ["music_video", "story", "hybrid", "video_only"],
      "description": "music_video | story | hybrid | video_only — docs/audio_motion_production_modes.md"
    },
    "mix_policy": { "type": "string" },
    "default_motion_driver": {
      "type": "string",
      "enum": ["i2v", "si2v", "still", "flf2v"]
    },
    "default_backend_i2v": { "type": "string" },
    "default_backend_s2v": { "type": ["string", "null"] },
    "default_deliver_tier": { "type": "string" },
    "default_model": { "type": "string" },
    "audio": {
      "type": "object",
      "properties": {
        "master": { "type": ["string", "null"] },
        "bgm": { "type": ["string", "null"] },
        "bgm_volume": { "type": "number" }
      }
    },
    "characters": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Default character_ids for shots that omit character_ids"
    },
    "locations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Known location_ids used in the episode"
    },
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["shot_id", "action"],
        "properties": {
          "shot_id": { "type": "string" },
          "order": { "type": "integer" },
          "scene_id": { "type": "string" },
          "duration_sec": { "type": "number" },
          "shot_type": { "type": "string" },
          "action": { "type": "string" },
          "motion_prompt": { "type": "string" },
          "motion_preset": {
            "type": "string",
            "description": "I2V motion intent id (idle, push_in, talk_gesture, …). See generate_i2v --list-motion-presets. episode_i2v composes with motion_prompt."
          },
          "i2v_motion_preset": {
            "type": "string",
            "description": "Alias of motion_preset"
          },
          "negative_motion": { "type": "string" },
          "motion_driver": {
            "type": "string",
            "enum": ["i2v", "si2v", "still", "flf2v", "v2v_camera", "v2v_motion", "v2v_style"]
          },
          "character_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "location_id": { "type": ["string", "null"] },
          "camera": { "type": "object" },
          "dialogue": { "type": "string" },
          "vo": { "type": "string" },
          "sfx": {
            "type": "array",
            "items": { "type": "string" }
          },
          "music_cue": { "type": "string" },
          "audio_refs": { "type": "object" }
        }
      }
    }
  }
}
