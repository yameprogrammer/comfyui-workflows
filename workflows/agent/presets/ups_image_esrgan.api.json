{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "example.png"
    },
    "_meta": { "title": "Load Image" }
  },
  "2": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "4x-UltraSharp.pth"
    },
    "_meta": { "title": "Load Upscale Model (style)" }
  },
  "3": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": ["2", 0],
      "image": ["1", 0]
    },
    "_meta": { "title": "Upscale Image (ESRGAN)" }
  },
  "4": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["3", 0],
      "upscale_method": "lanczos",
      "width": 1080,
      "height": 1920,
      "crop": "disabled"
    },
    "_meta": { "title": "Fit deliver size" }
  },
  "5": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["4", 0],
      "filename_prefix": "ups_esrgan"
    },
    "_meta": { "title": "Save Upscaled" }
  }
}
