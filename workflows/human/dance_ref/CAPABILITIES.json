    "i2v": "generate_i2v + dance style dialect"
  },
  "full_pipeline": "docs/dance_challenge_pipeline_design.md (not this CLI)",
  "not_included": [
    "Beat analysis / multi-shot challenge assemble",
    "OpenPose sequence retarget",
    "Copyright clearance"
  ]
}
